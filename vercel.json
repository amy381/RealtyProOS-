{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "routes": [
    { "src": "/api/fub/person/([^/]+)",      "dest": "/api/fub/person/[id]?id=$1" },
    { "src": "/api/google/auth",             "dest": "/api/google/auth" },
    { "src": "/api/google/callback",         "dest": "/api/google/callback" },
    { "src": "/api/google/status",           "dest": "/api/google/status" },
    { "src": "/api/google/token",            "dest": "/api/google/token" },
    { "src": "/api/google/move-folder",      "dest": "/api/google/move-folder" },
    { "src": "/api/google/create-folder",    "dest": "/api/google/create-folder" },
    { "src": "/api/google/gmail-send",       "dest": "/api/google/gmail-send" },
    { "src": "/api/google/gmail-status",     "dest": "/api/google/gmail-status" },
    { "src": "/api/vendor/fill-pdf",         "dest": "/api/vendor/fill-pdf" },
    { "src": "/api/fub/widget",              "dest": "/api/fub/widget" },
    { "src": "/api/(.*)",                    "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)",                        "dest": "/index.html" }
  ]
}
